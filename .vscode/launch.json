{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CoffeeShop (Flask)",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "cwd": "${workspaceFolder}/Project/03_coffee_shop_full_stack/starter_code/backend",
      "env": {
        "FLASK_APP": "src.api:app",
        "FLASK_DEBUG": "1",
        "FLASK_ENV": "development"
      },
      "args": [
        "run",
        "--host", "127.0.0.1",
        "--port", "5000",
        "--no-debugger",
        "--no-reload"
      ],
      "jinja": true,
      "autoStartBrowser": false
    }
  ]
}
